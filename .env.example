# Copy to .env and replace all CHANGE_ME values before running.

SPRING_PROFILES_ACTIVE=default
APP_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_NAME=flowdesk
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME
DB_URL=jdbc:postgresql://localhost:5432/flowdesk

DOCKER_DB_URL=jdbc:postgresql://postgres:5432/flowdesk
POSTGRES_DB=flowdesk
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# Base64-encoded secret
JWT_SECRET=CHANGE_ME_BASE64_SECRET
JWT_EXPIRATION_MS=86400000

STORAGE_PATH=uploads
SPRING_JPA_HIBERNATE_DDL_AUTO=update
