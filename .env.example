# Copy to .env and replace all CHANGE_ME values before running.

SPRING_PROFILES_ACTIVE=default
APP_PORT=8080

DB_HOST=localhost
DB_PORT=5433
DB_NAME=flowdesk
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_URL=jdbc:postgresql://localhost:5433/flowdesk
POSTGRES_DB=flowdesk
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

# Production example (Neon)
# DB_URL=jdbc:postgresql://<your-neon-host>/<your-db>?sslmode=require&channelBinding=require
# DB_USERNAME=<your-neon-user>
# DB_PASSWORD=<your-neon-password>

# Base64-encoded secret
JWT_SECRET=CHANGE_ME_BASE64_SECRET
JWT_EXPIRATION_MS=86400000

STORAGE_PATH=uploads
SPRING_JPA_HIBERNATE_DDL_AUTO=update
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,https://<your-vercel-domain>
